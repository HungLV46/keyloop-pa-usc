# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL / RDS)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=keyloop_appointments
DB_SSL=false

# Redis (ElastiCache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Booking config
HOLD_TTL_MINUTES=5
# Short-lived Redis lock to serialize concurrent hold attempts (ms)
LOCK_TTL_MS=500
